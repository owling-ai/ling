# 复制为 .env 后按需填写，启动时自动读取（shell 里已有的环境变量优先）。
# ⚠️ 同名 key 第一次出现的生效！同一个 key 只打开一行，其余示例保持注释。

# ---- 交互内核：Gemini Live / StepFun / MiniCPM-o / 火山引擎 RTC（任配一种，可在前端切换）
# GEMINI_API_KEY=...
# LING_GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview
# LING_GEMINI_VOICE=Aoede
# LING_GEMINI_SILENCE_MS=600           # 孩子说话多停顿，别设太小
# LING_GEMINI_TRANSCRIPTION_LANGUAGES=zh-CN,en-US
# LING_GEMINI_MAX_VIDEO_FRAME_CHARS=1200000
#
# STEPFUN_API_KEY=...
# LING_STEPFUN_MODEL=stepaudio-2.5-realtime
# LING_STEPFUN_VOICE=linjiajiejie      # 官方音色或克隆音色 ID
# LING_STEPFUN_SILENCE_MS=600
#
# 局域网 MiniCPM-o 4.5。BASE_URL 是 OpenAI compatible 的 /v1 地址；
# 若实时 WebSocket 不在同一路径，用 REALTIME_URL 显式覆盖。
# LING_MINICPM_BASE_URL=http://192.168.1.9:9000/v1
# LING_MINICPM_REALTIME_URL=ws://192.168.1.9:9000/v1/realtime
# LING_MINICPM_API_KEY=                 # 局域网无鉴权可留空
# LING_MINICPM_MODEL=MiniCPM-o-4.5
# LING_MINICPM_LENGTH_PENALTY=1.1
# LING_MINICPM_INPUT_CHUNK_MS=1000
# LING_MINICPM_QUEUE_TIMEOUT_SECONDS=120
# LING_MINICPM_MAX_VIDEO_FRAME_CHARS=1200000
# LING_MINICPM_USE_PROXY=0             # 局域网默认直连；确需走系统代理时设 1
#
# 火山引擎 AI 音视频互动方案（不是“实时对话式 AI”商品）
# 四项均为后端密钥；浏览器只会拿到短期 RTC Token。
# VOLCENGINE_RTC_APP_ID=...             # AI 音视频互动方案应用 AppId
# VOLCENGINE_RTC_APP_KEY=...            # 同一应用的 RTC AppKey
# VOLCENGINE_ACCESS_KEY=...             # 火山 IAM Access Key
# VOLCENGINE_SECRET_KEY=...             # 火山 IAM Secret Key
# LING_VOLC_ARK_MODEL=doubao-seed-2-1-turbo-260628
# LING_VOLC_ASR_RESOURCE_ID=volc.bigasr.sauc.duration
# LING_VOLC_TTS_RESOURCE_ID=volc.service_type.10029
# LING_VOLC_TTS_VOICE=zh_female_linjianvhai_moon_bigtts
# LING_VOLC_BUSINESS_ID=                # 控制台配置了 BusinessId 时填写
# LING_VOLC_TOKEN_TTL_SECONDS=3600
# LING_VOLC_IDLE_TIMEOUT_SECONDS=30
# LING_VOLC_VISION_INTERVAL_MS=1000
# 声纹默认自动学习当前用户 4 秒并过滤其他人声；正式产品建议改为预注册声纹 ID。
#
# 默认提供商：gemini | stepfun | volcengine | minicpm。不设置时依次选择已配置项。
# LING_REALTIME_PROVIDER=gemini
# HTTP 代理（websockets 16 会自动读取；wss 通常设置 HTTPS_PROXY）
# HTTPS_PROXY=http://127.0.0.1:7890

# ---- 冷路径：记忆工人（日记/事实/反思/夜间规划/生活时钟，异步不在乎延迟）
# 什么都不填 = 规则抽取器兜底，冷路径全流程照跑。
# 任何 OpenAI 兼容端点（SiliconFlow / OpenRouter / DeepSeek 官方 / 本地 ollama ...）：
# LING_WORKER_BASE_URL=https://api.siliconflow.cn/v1
# LING_WORKER_API_KEY=sk-...
# LING_WORKER_MODEL=deepseek-ai/DeepSeek-V4-Pro
# 非流式请求会等待模型完整响应；默认 60 秒，可设为 1-120 秒。
# LING_WORKER_TIMEOUT_SECONDS=60

# ---- 兼容旧配置：LING_OPENAI_* 等价于 LING_WORKER_*
# LING_OPENAI_BASE_URL=
# LING_OPENAI_API_KEY=
# LING_OPENAI_MODEL=

# ---- Anthropic 兜底（没配 OpenAI 兼容端点时启用）
# ANTHROPIC_API_KEY=sk-ant-...
# LING_ANTHROPIC_WORKER_MODEL=claude-haiku-4-5

# ---- 视频生成：即梦 / 火山方舟 Seedance 2.0（可选）
# 黑客松现场默认保持 mock；只有显式选择 jimeng 且配置 Key 才会调用真实 API。
# 请求 jimeng 但缺少 Key 时自动降级到 mock，不创建或积压真实生成任务。
# LING_MEDIA_PROVIDER=jimeng               # mock | jimeng（ark / seedance 也是别名）
# ARK_API_KEY=...                          # 方舟 API Key，不是 RTC 的 IAM AK/SK
# LING_ARK_VIDEO_MODEL=doubao-seedance-2-0-260128
# LING_ARK_VIDEO_REFERENCE_IMAGE_URL=https://.../ling-reference.png
# LING_ARK_VIDEO_DURATION_SECONDS=6        # 2-12 秒，世界线建议 5-7 秒
# LING_ARK_VIDEO_RESOLUTION=720p           # 480p | 720p | 1080p
# LING_ARK_VIDEO_POLL_SECONDS=10
# LING_ARK_VIDEO_TIMEOUT_SECONDS=1800
# LING_ARK_VIDEO_MAX_FAILURES=5
# LING_MEDIA_MAX_DOWNLOAD_BYTES=104857600
# LING_GENERATED_MEDIA_ROOT=data/generated_media
# LING_MEDIA_WORKER_ENABLED=1
# LING_MEDIA_WORKER_INTERVAL_SECONDS=2
# LING_MEDIA_WORKER_BATCH_SIZE=10

# ---- 其他
# 强制指定记忆工人引擎：openai | anthropic | mock
# LING_PROVIDER=openai
# 数据库位置（默认 data/ling.db）
# LING_DB=data/ling.db
# 反代/跨域来源白名单（默认已含 mm.liaoxingyi.com 与本机）
# LING_CORS_ORIGINS=https://mm.liaoxingyi.com,http://localhost:8888
