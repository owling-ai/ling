# 复制为 .env 后按需填写，启动时自动读取（shell 里已有的环境变量优先）。
# ⚠️ 同名 key 第一次出现的生效！同一个 key 只打开一行，其余示例保持注释。

# ---- 交互内核：Gemini Live / StepFun Realtime（二选一即可，同时配置可在前端切换）
# GEMINI_API_KEY=...
# LING_GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview
# LING_GEMINI_VOICE=Aoede
# LING_GEMINI_SILENCE_MS=600           # 孩子说话多停顿，别设太小
# LING_GEMINI_TRANSCRIPTION_LANGUAGES=zh-CN,en-US
# LING_GEMINI_MAX_VIDEO_FRAME_CHARS=1200000
#
# STEPFUN_API_KEY=...
# LING_STEPFUN_MODEL=stepaudio-2.5-realtime
# LING_STEPFUN_VOICE=linjiajiejie      # 官方音色或克隆音色 ID
# LING_STEPFUN_SILENCE_MS=600
#
# 默认提供商：gemini | stepfun。不设置时优先 Gemini，其次 StepFun。
# LING_REALTIME_PROVIDER=gemini
# HTTP 代理（websockets 16 会自动读取；wss 通常设置 HTTPS_PROXY）
# HTTPS_PROXY=http://127.0.0.1:7890

# ---- 冷路径：记忆工人（日记/事实/反思/夜间规划/生活时钟，异步不在乎延迟）
# 什么都不填 = 规则抽取器兜底，冷路径全流程照跑。
# 任何 OpenAI 兼容端点（SiliconFlow / OpenRouter / DeepSeek 官方 / 本地 ollama ...）：
# LING_WORKER_BASE_URL=https://api.siliconflow.cn/v1
# LING_WORKER_API_KEY=sk-...
# LING_WORKER_MODEL=deepseek-ai/DeepSeek-V4-Pro

# ---- 兼容旧配置：LING_OPENAI_* 等价于 LING_WORKER_*
# LING_OPENAI_BASE_URL=
# LING_OPENAI_API_KEY=
# LING_OPENAI_MODEL=

# ---- Anthropic 兜底（没配 OpenAI 兼容端点时启用）
# ANTHROPIC_API_KEY=sk-ant-...
# LING_ANTHROPIC_WORKER_MODEL=claude-haiku-4-5

# ---- 其他
# 强制指定记忆工人引擎：openai | anthropic | mock
# LING_PROVIDER=openai
# 数据库位置（默认 data/ling.db）
# LING_DB=data/ling.db
# 反代/跨域来源白名单（默认已含 mm.liaoxingyi.com 与本机）
# LING_CORS_ORIGINS=https://mm.liaoxingyi.com,http://localhost:8888
